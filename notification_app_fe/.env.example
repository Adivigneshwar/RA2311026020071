# Environment configuration for React frontend
# Copy this to .env.local and update values for your setup

# API base URL - where backend notification service runs
REACT_APP_API_BASE_URL=http://localhost:5000

# (Optional) Auth token endpoint if backend requires manual token management
# REACT_APP_AUTH_ENDPOINT=/evaluation-service/auth

# (Optional) Custom logging service endpoint
# REACT_APP_LOGGING_ENDPOINT=/evaluation-service/logs
